# Optional: token for publishing to the FoundryVTT package registry.
# Get one at https://foundryvtt.com/me/edit (Edit Account → Auth Tokens).
# Without this, release.sh just creates a GitHub release.
FOUNDRY_RELEASE_TOKEN=

# Local Foundry modules directory; consumed by dev-install.sh so the script
# knows where to drop the source tree for in-place testing.
# WSL example:  /mnt/c/Users/you/FoundryVTT-WindowsPortable-14.x/Data/modules
# macOS:        $HOME/Library/Application Support/FoundryVTT/Data/modules
# Linux:        $HOME/.local/share/FoundryVTT/Data/modules
FOUNDRY_MODULES_DIR=
